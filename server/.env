PORT=5000

# Agar aap apne computer (Local) par MongoDB chala rahe hain toh yeh line uncomment karein:
# MONGO_URI=mongodb://127.0.0.1:27017/afterus_crm

# Agar aap MongoDB Atlas (Cloud Database) use kar rahe hain, toh yahan apna connection string daalein:
MONGO_URI=mongodb://127.0.0.1:27017/afterus_crm
# JWT Token ke liye ek secret key (Isko aise hi rehne dein)
JWT_SECRET=AfterUs_Super_Secret_Key_2026!